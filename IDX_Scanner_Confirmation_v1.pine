//@version=6
indicator("IDX Scanner Confirmation v1.1 — Entry SL TP", overlay = true, max_labels_count = 300, max_lines_count = 100, max_boxes_count = 50)

// ============================================================================
// PURPOSE
// 1) Confirm the output of IDX Super Scanner on TradingView.
// 2) Plot entry zone, stop loss, TP1, TP2 and a directional-bias score.
// 3) Detect Pullback Continuation, Breakout Retest, Reversal Accumulation,
//    ICT Sniper, BPJS, BSJP and ARA Hunter proxies.
//
// IMPORTANT
// - This is a confirmation indicator, not an order-routing system.
// - "Directional score" is a rules-based confluence score, not a calibrated
//   probability and not a guarantee of future price movement.
// - Use alerts on bar close to reduce repaint/incomplete-bar risk.
// ============================================================================

// ---------- Inputs ----------
groupMode = "1. Mode & Integration"
mode = input.string("AUTO", "Setup mode", options = ["AUTO", "MANUAL SCANNER LEVELS", "PULLBACK CONTINUATION", "BREAKOUT RETEST", "ICT SNIPER", "REVERSAL ACCUMULATION", "BPJS", "BSJP", "ARA HUNTER"], group = groupMode)
scannerTag = input.string("", "Scanner setup/status note", group = groupMode, tooltip = "Optional note copied from the Streamlit scanner.")
useManualLevels = mode == "MANUAL SCANNER LEVELS"
manualEntryLow = input.float(0.0, "Scanner entry low", minval = 0.0, group = groupMode)
manualEntryHigh = input.float(0.0, "Scanner entry high", minval = 0.0, group = groupMode)
manualEntry = input.float(0.0, "Scanner order entry", minval = 0.0, group = groupMode)
manualSL = input.float(0.0, "Scanner stop loss", minval = 0.0, group = groupMode)
manualTP1 = input.float(0.0, "Scanner TP1", minval = 0.0, group = groupMode)
manualTP2 = input.float(0.0, "Scanner TP2", minval = 0.0, group = groupMode)

benchmarkSymbol = input.symbol("IDX:COMPOSITE", "IHSG benchmark", group = groupMode)
requireMarketSupport = input.bool(true, "Require IHSG not RISK_OFF", group = groupMode)
confirmedBarOnly = input.bool(true, "Signal only on closed bar", group = groupMode)

groupRisk = "2. Risk & Execution"
atrLen = input.int(14, "ATR length", minval = 5, maxval = 50, group = groupRisk)
maxStopPct = input.float(7.0, "Maximum stop distance (%)", minval = 1.0, maxval = 15.0, step = 0.5, group = groupRisk) / 100.0
minRR1 = input.float(1.8, "Minimum RR TP1", minval = 1.0, maxval = 5.0, step = 0.1, group = groupRisk)
minRR2 = input.float(2.7, "Minimum RR TP2", minval = 1.5, maxval = 8.0, step = 0.1, group = groupRisk)
minDirectionScore = input.int(60, "Minimum directional score", minval = 40, maxval = 90, group = groupRisk)
maxDistanceATR = input.float(0.35, "Maximum distance from entry zone (ATR)", minval = 0.0, maxval = 2.0, step = 0.05, group = groupRisk)
blockNearARA = input.bool(true, "Block entry near ARA", group = groupRisk)
minRoomToARA = input.float(4.0, "Minimum remaining room to ARA (%)", minval = 0.0, maxval = 20.0, step = 0.5, group = groupRisk) / 100.0

groupStructure = "3. Structure"
pivotLen = input.int(3, "Confirmed pivot length", minval = 2, maxval = 10, group = groupStructure)
showEMA = input.bool(true, "Plot EMA20/50/200", group = groupStructure)
showSignals = input.bool(true, "Show setup labels", group = groupStructure)
showDashboard = input.bool(true, "Show dashboard", group = groupStructure)
enableDynamicAlert = input.bool(true, "Enable dynamic alert() call", group = groupStructure)

// ---------- IDX price helpers ----------
f_tick(float p) =>
    p < 200.0 ? 1.0 : p < 500.0 ? 2.0 : p < 2000.0 ? 5.0 : p < 5000.0 ? 10.0 : 25.0

f_round_up(float p) =>
    float t1 = f_tick(math.max(p, 1.0))
    float r1 = math.ceil(p / t1) * t1
    float t2 = f_tick(math.max(r1, 1.0))
    math.ceil(r1 / t2) * t2

f_round_down(float p) =>
    float t1 = f_tick(math.max(p, 1.0))
    float r1 = math.floor(p / t1) * t1
    float t2 = f_tick(math.max(r1, 1.0))
    math.floor(r1 / t2) * t2

f_clamp(float x, float lo, float hi) =>
    math.max(lo, math.min(hi, x))

f_distance_to_zone(float price, float lo, float hi, float atrValue) =>
    atrValue <= 0.0 or na(lo) or na(hi) ? 999.0 : price >= lo and price <= hi ? 0.0 : price > hi ? (price - hi) / atrValue : (lo - price) / atrValue

f_ara_rate(float referencePrice) =>
    referencePrice <= 200.0 ? 0.35 : referencePrice <= 5000.0 ? 0.25 : 0.20

f_bias_text(float score) =>
    score >= 70 ? "BULLISH" : score >= 58 ? "BULLISH LEAN" : score >= 45 ? "NEUTRAL" : score >= 32 ? "BEARISH LEAN" : "BEARISH"

f_bias_color(float score) =>
    score >= 70 ? color.new(color.lime, 0) : score >= 58 ? color.new(color.green, 0) : score >= 45 ? color.new(color.orange, 0) : color.new(color.red, 0)

// ---------- Core indicators ----------
float atr = ta.atr(atrLen)
float ema20 = ta.ema(close, 20)
float ema50 = ta.ema(close, 50)
float ema200 = ta.ema(close, 200)
float volMA20 = ta.sma(volume, 20)
float volRatio = volMA20 > 0 ? volume / volMA20 : na
float rsi14 = ta.rsi(close, 14)
float roc20 = ta.roc(close, 20)
float roc60 = ta.roc(close, 60)
[plusDI, minusDI, adx14] = ta.dmi(14, 14)

float moneyFlowMultiplier = high != low ? ((close - low) - (high - close)) / (high - low) : 0.0
float moneyFlowVolume = moneyFlowMultiplier * volume
float cmf20 = ta.sum(moneyFlowVolume, 20) / math.max(ta.sum(volume, 20), 1.0)
float obv = ta.cum(math.sign(ta.change(close)) * volume)
float obvSlope10 = ta.linreg(obv, 10, 0) - ta.linreg(obv, 10, 1)
float closeLocation = high != low ? (close - low) / (high - low) : 0.5
float bodyATR = atr > 0 ? math.abs(close - open) / atr : 0.0
float rangeATR = atr > 0 ? (high - low) / atr : 0.0
bool bullishRejection = close > open and closeLocation >= 0.60 and (math.min(open, close) - low) >= math.abs(close - open) * 0.65

float pivotHigh = ta.pivothigh(high, pivotLen, pivotLen)
float pivotLow = ta.pivotlow(low, pivotLen, pivotLen)
float lastPivotHigh = ta.valuewhen(not na(pivotHigh), pivotHigh, 0)
float lastPivotLow = ta.valuewhen(not na(pivotLow), pivotLow, 0)
float high20Prev = ta.highest(high[1], 20)
float low20Prev = ta.lowest(low[1], 20)
float high55Prev = ta.highest(high[1], 55)
float high252 = ta.highest(high, 252)
float distance52wHigh = high252 > 0 ? close / high252 - 1.0 : na

// Confirmed daily IHSG regime. The one-bar offset with lookahead_on is the
// recommended non-repainting HTF pattern for completed higher-timeframe data.
[benchCloseD, benchEma50D, benchEma200D, benchRoc20D] = request.security(benchmarkSymbol, "D", [close[1], ta.ema(close, 50)[1], ta.ema(close, 200)[1], ta.roc(close, 20)[1]], lookahead = barmerge.lookahead_on)
bool ihsgRiskOn = benchCloseD > benchEma50D and benchEma50D > benchEma200D and benchRoc20D > 0
bool ihsgRiskOff = benchCloseD < benchEma200D and benchRoc20D < 0
string marketRegime = ihsgRiskOn ? "RISK_ON" : ihsgRiskOff ? "RISK_OFF" : "NEUTRAL"

// Relative strength proxy versus confirmed daily IHSG.
float stockDailyRoc60 = request.security(syminfo.tickerid, "D", ta.roc(close, 60)[1], lookahead = barmerge.lookahead_on)
float benchDailyRoc60 = request.security(benchmarkSymbol, "D", ta.roc(close, 60)[1], lookahead = barmerge.lookahead_on)
float relativeStrength60 = stockDailyRoc60 - benchDailyRoc60

// ---------- Directional confluence score ----------
float directionScore = 0.0
directionScore += close > ema20 and ema20 > ema50 and ema50 > ema200 ? 25.0 : close > ema50 and ema50 > ema200 ? 15.0 : close > ema20 ? 7.0 : 0.0
directionScore += close > lastPivotHigh ? 15.0 : close > high20Prev ? 10.0 : close < lastPivotLow ? -12.0 : 3.0
directionScore += roc20 > 5 and roc60 > 8 ? 12.0 : roc20 > 0 and roc60 > 0 ? 7.0 : roc20 < 0 and roc60 < 0 ? -8.0 : 0.0
directionScore += rsi14 >= 52 and rsi14 <= 72 ? 8.0 : rsi14 > 72 ? 3.0 : rsi14 < 42 ? -6.0 : 2.0
directionScore += adx14 >= 20 and plusDI > minusDI ? 8.0 : adx14 >= 20 and plusDI < minusDI ? -6.0 : 2.0
directionScore += cmf20 > 0.05 and obvSlope10 > 0 ? 10.0 : cmf20 > 0 and obvSlope10 > 0 ? 6.0 : cmf20 < -0.05 ? -7.0 : 0.0
directionScore += volRatio >= 1.5 and closeLocation >= 0.65 ? 7.0 : volRatio >= 1.1 ? 3.0 : 0.0
directionScore += relativeStrength60 > 5 ? 7.0 : relativeStrength60 > 0 ? 4.0 : relativeStrength60 < -5 ? -5.0 : 0.0
directionScore += ihsgRiskOn ? 8.0 : ihsgRiskOff ? -10.0 : 2.0
directionScore := f_clamp(directionScore, 0.0, 100.0)
string directionBias = f_bias_text(directionScore)

// ---------- Setup 1: Pullback Continuation ----------
bool pbTrend = ema20 > ema50 and ema50 > ema200 and close > ema50 and ema20 > ema20[10]
bool pbMomentum = roc60 > 4 and distance52wHigh > -0.18
bool pbTouched = ta.lowest(low - ema20, 5) <= 0.35 * atr
bool pbHeld = close >= ema50 - 0.25 * atr
bool pbVolumeContract = ta.sma(volume[1], 4) < 0.92 * volMA20
bool pbFlow = cmf20 >= 0 and obvSlope10 > 0
bool pbConfirm = bullishRejection or (close > high[1] and close > open)
float pbZoneLow = ema20 - 0.35 * atr
float pbZoneHigh = ema20 + 0.40 * atr
float pbDistance = f_distance_to_zone(close, pbZoneLow, pbZoneHigh, atr)
bool pbDetected = pbTrend and pbMomentum and pbTouched and pbHeld
bool pbReady = pbDetected and pbConfirm and pbVolumeContract and pbFlow and adx14 >= 18 and pbDistance <= maxDistanceATR
float pbEntry = pbReady ? f_round_up(math.max(close, high + f_tick(close))) : f_round_up((pbZoneLow + pbZoneHigh) / 2.0)
float pbStopRaw = math.min(ta.lowest(low, 7), nz(lastPivotLow, ta.lowest(low, 7))) - 0.20 * atr

// ---------- Setup 2: Breakout Retest ----------
bool breakoutBar = close > high55Prev + 0.05 * atr and volRatio >= 1.25 and bodyATR >= 0.40 and close > open
float lastBreakoutLevel = ta.valuewhen(breakoutBar, high55Prev, 0)
int lastBreakoutIndex = int(ta.valuewhen(breakoutBar, bar_index, 0))
bool breakoutRecent = not na(lastBreakoutLevel) and bar_index - lastBreakoutIndex <= 18
bool retestNow = breakoutRecent and low <= lastBreakoutLevel + 0.45 * atr and low >= lastBreakoutLevel - 1.0 * atr and close >= lastBreakoutLevel - 0.10 * atr
bool brTrend = ema20 > ema50 and ema50 > ema200
bool brConfirm = bullishRejection or (close > high[1] and close > open)
float brZoneLow = lastBreakoutLevel - 0.45 * atr
float brZoneHigh = lastBreakoutLevel + 0.35 * atr
float brDistance = f_distance_to_zone(close, brZoneLow, brZoneHigh, atr)
bool brDetected = breakoutRecent and brTrend and close >= lastBreakoutLevel - 1.15 * atr
bool brReady = brDetected and retestNow and brConfirm and brDistance <= maxDistanceATR
float brEntry = brReady ? f_round_up(math.max(close, high + f_tick(close))) : f_round_up(lastBreakoutLevel + 0.10 * atr)
float brStopRaw = math.min(ta.lowest(low, 5), lastBreakoutLevel - 0.70 * atr) - 0.15 * atr

// ---------- Setup 3: ICT Sniper ----------
bool sellSideSweep = low < low20Prev and close > low20Prev and closeLocation >= 0.55
int lastSweepIndex = int(ta.valuewhen(sellSideSweep, bar_index, 0))
float lastSweepLow = ta.valuewhen(sellSideSweep, low, 0)
bool bosBar = close > lastPivotHigh + 0.05 * atr and bodyATR >= 0.55 and close > open
bool bosAfterSweep = bosBar and not na(lastSweepLow) and bar_index > lastSweepIndex and bar_index - lastSweepIndex <= 20
int lastBosIndex = int(ta.valuewhen(bosAfterSweep, bar_index, 0))
bool bullFVG = low > high[2] and close[1] > open[1] and bodyATR[1] >= 0.55 and volRatio[1] >= 1.15
bool fvgAfterBos = bullFVG and not na(lastBosIndex) and bar_index >= lastBosIndex and bar_index - lastBosIndex <= 6
int lastFvgIndex = int(ta.valuewhen(fvgAfterBos, bar_index, 0))
float sniperFvgLow = ta.valuewhen(fvgAfterBos, high[2], 0)
float sniperFvgHigh = ta.valuewhen(fvgAfterBos, low, 0)
bool sniperSequence = not na(lastSweepLow) and not na(lastBosIndex) and not na(lastFvgIndex) and lastSweepIndex < lastBosIndex and lastBosIndex <= lastFvgIndex and bar_index - lastFvgIndex <= 30
float sniperEq = (lastSweepLow + nz(lastPivotHigh, high20Prev)) / 2.0
bool sniperDiscount = (sniperFvgLow + sniperFvgHigh) / 2.0 <= sniperEq
float sniperDistance = f_distance_to_zone(close, sniperFvgLow, sniperFvgHigh, atr)
bool sniperConfirm = bullishRejection or close > high[1]
bool sniperDetected = sniperSequence and sniperFvgHigh > sniperFvgLow and close >= lastSweepLow
bool sniperReady = sniperDetected and sniperDiscount and volRatio >= 1.20 and cmf20 > 0 and obvSlope10 > 0 and sniperConfirm and sniperDistance <= maxDistanceATR
float sniperEntry = sniperReady ? f_round_up(math.max(close, high + f_tick(close))) : f_round_up((sniperFvgLow + sniperFvgHigh) / 2.0)
float sniperStopRaw = math.min(lastSweepLow, sniperFvgLow - 0.45 * atr) - 0.10 * atr

// ---------- Setup 4: Reversal Accumulation ----------
float priorHigh120 = ta.highest(high[30], 120)
float baseLow30 = ta.lowest(low, 30)
float baseHigh30 = ta.highest(high, 30)
float declineFromPrior = priorHigh120 > 0 ? baseLow30 / priorHigh120 - 1.0 : 0.0
float baseWidth = close > 0 ? (baseHigh30 - baseLow30) / close : 1.0
bool based = declineFromPrior <= -0.12 and baseWidth <= 0.24
bool accumulation = ta.sma(cmf20, 10) > 0.02 and obvSlope10 > 0
bool chochBar = close > lastPivotHigh + 0.05 * atr and close > ema20 and volRatio >= 1.05
int lastChochIndex = int(ta.valuewhen(chochBar and not na(lastSweepLow) and bar_index >= lastSweepIndex, bar_index, 0))
float reversalLevel = ta.valuewhen(chochBar and not na(lastSweepLow) and bar_index >= lastSweepIndex, lastPivotHigh, 0)
bool reversalSequence = based and accumulation and not na(lastSweepLow) and not na(lastChochIndex) and lastChochIndex >= lastSweepIndex and bar_index - lastChochIndex <= 20
float revZoneLow = reversalLevel - 0.45 * atr
float revZoneHigh = reversalLevel + 0.35 * atr
float revDistance = f_distance_to_zone(close, revZoneLow, revZoneHigh, atr)
bool revConfirm = bullishRejection or close > high[1]
bool revDetected = reversalSequence and close >= lastSweepLow
bool revReady = revDetected and revConfirm and cmf20 > 0.03 and obvSlope10 > 0 and revDistance <= maxDistanceATR
float revEntry = revReady ? f_round_up(math.max(close, high + f_tick(close))) : f_round_up((revZoneLow + revZoneHigh) / 2.0)
float revStopRaw = lastSweepLow - 0.20 * atr

// ---------- Intraday session state for BPJS / BSJP ----------
int jktHour = hour(time, "Asia/Jakarta")
int jktMinute = minute(time, "Asia/Jakarta")
int jktMinutes = jktHour * 60 + jktMinute
bool newSessionDay = ta.change(time("D")) != 0
bool inOpeningRange = jktMinutes >= 540 and jktMinutes < 555      // 09:00–09:15
bool inBPJSWindow = jktMinutes >= 560 and jktMinutes <= 645       // 09:20–10:45
bool inBSJPWindow = jktMinutes >= 870 and jktMinutes <= 949       // 14:30–15:49
var float orbHigh = na
var float orbLow = na
var int barsToday = 0
if newSessionDay
    orbHigh := na
    orbLow := na
    barsToday := 0
barsToday += 1
if inOpeningRange
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow := na(orbLow) ? low : math.min(orbLow, low)

float sessionVWAP = ta.vwap(hlc3)
float prevDailyClose = request.security(syminfo.tickerid, "D", close[1], lookahead = barmerge.lookahead_on)
float openingGap = prevDailyClose > 0 ? open / prevDailyClose - 1.0 : na
bool intradayFrameOK = timeframe.isintraday and timeframe.in_seconds() <= 900
bool bpjsDetected = intradayFrameOK and not na(orbHigh) and close > orbHigh and close > sessionVWAP and ema20 >= ema50 and relativeStrength60 > 0
bool bpjsReady = bpjsDetected and inBPJSWindow and volRatio >= 1.30 and closeLocation >= 0.70 and openingGap >= -0.015 and openingGap <= 0.035
float bpjsZoneLow = orbHigh
float bpjsZoneHigh = orbHigh + 0.20 * atr
float bpjsEntry = f_round_up(math.max(close, orbHigh + f_tick(close)))
float bpjsStopRaw = math.max(nz(orbLow, low), ta.lowest(low, 3)) - f_tick(close)

bool bsjpDetected = intradayFrameOK and inBSJPWindow and close >= sessionVWAP and volRatio >= 1.10 and cmf20 >= 0.03 and obvSlope10 > 0 and closeLocation >= 0.65 and relativeStrength60 > 0
bool bsjpReady = bsjpDetected and volRatio >= 1.25 and closeLocation >= 0.72 and directionScore >= 65
float bsjpZoneLow = close - 0.15 * atr
float bsjpZoneHigh = close + 0.10 * atr
float bsjpEntry = f_round_down(close)
float bsjpStopRaw = ta.lowest(low, 4) - f_tick(close)

// ---------- ARA Hunter proxy ----------
float araPrice = f_round_down(prevDailyClose * (1.0 + f_ara_rate(prevDailyClose)))
float roomToARA = close > 0 and not na(araPrice) ? araPrice / close - 1.0 : na
bool araDetected = close > high20Prev and volRatio >= 1.8 and closeLocation >= 0.80 and bodyATR >= 0.70 and cmf20 > 0 and obvSlope10 > 0 and roc20 > 2
bool araReady = araDetected and roomToARA >= minRoomToARA and openingGap <= 0.08 and rsi14 <= 78
float araZoneLow = close - 0.15 * atr
float araZoneHigh = close + 0.10 * atr
float araEntry = f_round_up(close)
float araStopRaw = close - math.min(0.04 * close, math.max(1.10 * atr, 3.0 * f_tick(close)))

// ---------- Select setup ----------
string selectedSetup = "NONE"
bool selectedDetected = false
bool selectedReady = false
float entryLow = na
float entryHigh = na
float orderEntry = na
float stopRaw = na
float customTP1 = na
float customTP2 = na

if useManualLevels
    selectedSetup := scannerTag == "" ? "MANUAL SCANNER" : scannerTag
    entryLow := manualEntryLow > 0 ? manualEntryLow : manualEntry
    entryHigh := manualEntryHigh > 0 ? manualEntryHigh : manualEntry
    orderEntry := manualEntry > 0 ? manualEntry : (entryLow + entryHigh) / 2.0
    stopRaw := manualSL
    customTP1 := manualTP1
    customTP2 := manualTP2
    selectedDetected := orderEntry > 0 and stopRaw > 0
    selectedReady := selectedDetected and bullishRejection and f_distance_to_zone(close, entryLow, entryHigh, atr) <= maxDistanceATR
else if mode == "PULLBACK CONTINUATION"
    selectedSetup := "PULLBACK CONTINUATION"
    selectedDetected := pbDetected
    selectedReady := pbReady
    entryLow := pbZoneLow
    entryHigh := pbZoneHigh
    orderEntry := pbEntry
    stopRaw := pbStopRaw
else if mode == "BREAKOUT RETEST"
    selectedSetup := "BREAKOUT RETEST"
    selectedDetected := brDetected
    selectedReady := brReady
    entryLow := brZoneLow
    entryHigh := brZoneHigh
    orderEntry := brEntry
    stopRaw := brStopRaw
else if mode == "ICT SNIPER"
    selectedSetup := "ICT SNIPER"
    selectedDetected := sniperDetected
    selectedReady := sniperReady
    entryLow := sniperFvgLow
    entryHigh := sniperFvgHigh
    orderEntry := sniperEntry
    stopRaw := sniperStopRaw
else if mode == "REVERSAL ACCUMULATION"
    selectedSetup := "REVERSAL ACCUMULATION"
    selectedDetected := revDetected
    selectedReady := revReady
    entryLow := revZoneLow
    entryHigh := revZoneHigh
    orderEntry := revEntry
    stopRaw := revStopRaw
else if mode == "BPJS"
    selectedSetup := "BPJS"
    selectedDetected := bpjsDetected
    selectedReady := bpjsReady
    entryLow := bpjsZoneLow
    entryHigh := bpjsZoneHigh
    orderEntry := bpjsEntry
    stopRaw := bpjsStopRaw
else if mode == "BSJP"
    selectedSetup := "BSJP"
    selectedDetected := bsjpDetected
    selectedReady := bsjpReady
    entryLow := bsjpZoneLow
    entryHigh := bsjpZoneHigh
    orderEntry := bsjpEntry
    stopRaw := bsjpStopRaw
else if mode == "ARA HUNTER"
    selectedSetup := "ARA HUNTER"
    selectedDetected := araDetected
    selectedReady := araReady
    entryLow := araZoneLow
    entryHigh := araZoneHigh
    orderEntry := araEntry
    stopRaw := araStopRaw
else
    // AUTO prioritizes the more selective structural setup. Intraday modes are
    // selected only during their relevant windows.
    if intradayFrameOK and inBPJSWindow and bpjsDetected
        selectedSetup := "BPJS"
        selectedDetected := bpjsDetected
        selectedReady := bpjsReady
        entryLow := bpjsZoneLow
        entryHigh := bpjsZoneHigh
        orderEntry := bpjsEntry
        stopRaw := bpjsStopRaw
    else if intradayFrameOK and inBSJPWindow and bsjpDetected
        selectedSetup := "BSJP"
        selectedDetected := bsjpDetected
        selectedReady := bsjpReady
        entryLow := bsjpZoneLow
        entryHigh := bsjpZoneHigh
        orderEntry := bsjpEntry
        stopRaw := bsjpStopRaw
    else if sniperDetected
        selectedSetup := "ICT SNIPER"
        selectedDetected := sniperDetected
        selectedReady := sniperReady
        entryLow := sniperFvgLow
        entryHigh := sniperFvgHigh
        orderEntry := sniperEntry
        stopRaw := sniperStopRaw
    else if brDetected
        selectedSetup := "BREAKOUT RETEST"
        selectedDetected := brDetected
        selectedReady := brReady
        entryLow := brZoneLow
        entryHigh := brZoneHigh
        orderEntry := brEntry
        stopRaw := brStopRaw
    else if pbDetected
        selectedSetup := "PULLBACK CONTINUATION"
        selectedDetected := pbDetected
        selectedReady := pbReady
        entryLow := pbZoneLow
        entryHigh := pbZoneHigh
        orderEntry := pbEntry
        stopRaw := pbStopRaw
    else if revDetected
        selectedSetup := "REVERSAL ACCUMULATION"
        selectedDetected := revDetected
        selectedReady := revReady
        entryLow := revZoneLow
        entryHigh := revZoneHigh
        orderEntry := revEntry
        stopRaw := revStopRaw
    else if araDetected
        selectedSetup := "ARA HUNTER"
        selectedDetected := araDetected
        selectedReady := araReady
        entryLow := araZoneLow
        entryHigh := araZoneHigh
        orderEntry := araEntry
        stopRaw := araStopRaw

// ---------- Final price plan and execution gate ----------
float entryRounded = not na(orderEntry) ? f_round_up(orderEntry) : na
float stopRounded = not na(stopRaw) ? f_round_down(stopRaw) : na
float riskValue = not na(entryRounded) and not na(stopRounded) ? entryRounded - stopRounded : na
float tp1 = useManualLevels and customTP1 > 0 ? f_round_up(customTP1) : not na(riskValue) and riskValue > 0 ? f_round_up(entryRounded + minRR1 * riskValue) : na
float tp2 = useManualLevels and customTP2 > 0 ? f_round_up(customTP2) : not na(riskValue) and riskValue > 0 ? f_round_up(entryRounded + minRR2 * riskValue) : na
float stopPct = not na(riskValue) and entryRounded > 0 ? riskValue / entryRounded : na
float rr1 = not na(tp1) and riskValue > 0 ? (tp1 - entryRounded) / riskValue : na
float rr2 = not na(tp2) and riskValue > 0 ? (tp2 - entryRounded) / riskValue : na
float selectedDistance = f_distance_to_zone(close, entryLow, entryHigh, atr)
bool barGate = not confirmedBarOnly or barstate.isconfirmed
bool marketGate = not requireMarketSupport or marketRegime != "RISK_OFF"
bool araGate = not blockNearARA or na(roomToARA) or roomToARA >= minRoomToARA
bool levelGate = not na(entryRounded) and not na(stopRounded) and not na(tp1) and not na(tp2) and stopRounded < entryRounded and entryRounded < tp1 and tp1 < tp2
bool riskGate = levelGate and stopPct > 0 and stopPct <= maxStopPct and rr1 >= minRR1 and rr2 >= minRR2
bool biasGate = directionScore >= minDirectionScore
bool executionReady = selectedDetected and selectedReady and barGate and marketGate and araGate and riskGate and biasGate
bool watchlistReady = selectedDetected and not executionReady

string primaryBlocker = not selectedDetected ? "NO SETUP" : not selectedReady ? "WAIT TRIGGER / RETEST" : not barGate ? "BAR NOT CLOSED" : not marketGate ? "IHSG RISK_OFF" : not araGate ? "TOO CLOSE TO ARA" : not levelGate ? "INVALID LEVELS" : not riskGate ? "RISK / RR GATE" : not biasGate ? "DIRECTION SCORE LOW" : "NONE"

// ---------- Visuals ----------
plot(showEMA ? ema20 : na, "EMA20", color = color.new(color.teal, 0), linewidth = 1)
plot(showEMA ? ema50 : na, "EMA50", color = color.new(color.orange, 0), linewidth = 1)
plot(showEMA ? ema200 : na, "EMA200", color = color.new(color.gray, 0), linewidth = 2)

pEntryLow = plot(selectedDetected ? f_round_down(entryLow) : na, "Entry zone low", color = color.new(color.aqua, 10), linewidth = 1, style = plot.style_linebr)
pEntryHigh = plot(selectedDetected ? f_round_up(entryHigh) : na, "Entry zone high", color = color.new(color.aqua, 10), linewidth = 1, style = plot.style_linebr)
fill(pEntryLow, pEntryHigh, color = color.new(color.aqua, 88), title = "Entry zone")
plot(selectedDetected ? entryRounded : na, "Order entry", color = color.new(color.blue, 0), linewidth = 2, style = plot.style_linebr)
plot(selectedDetected ? stopRounded : na, "Stop loss", color = color.new(color.red, 0), linewidth = 2, style = plot.style_linebr)
plot(selectedDetected ? tp1 : na, "TP1", color = color.new(color.green, 0), linewidth = 1, style = plot.style_linebr)
plot(selectedDetected ? tp2 : na, "TP2", color = color.new(color.lime, 0), linewidth = 2, style = plot.style_linebr)
plot(mode == "BPJS" or mode == "AUTO" ? orbHigh : na, "ORB high", color = color.new(color.yellow, 20), style = plot.style_linebr)
plot(mode == "BPJS" or mode == "BSJP" or mode == "AUTO" ? sessionVWAP : na, "Session VWAP", color = color.new(color.purple, 20), style = plot.style_linebr)

bgcolor(executionReady ? color.new(color.green, 90) : watchlistReady ? color.new(color.orange, 94) : na)

bool newReadySignal = executionReady and not executionReady[1]
if showSignals and newReadySignal
    label.new(bar_index, low, "ENTRY READY\n" + selectedSetup + "\nE " + str.tostring(entryRounded, format.mintick) + " | SL " + str.tostring(stopRounded, format.mintick) + "\nTP1 " + str.tostring(tp1, format.mintick) + " | TP2 " + str.tostring(tp2, format.mintick), style = label.style_label_up, color = color.new(color.green, 0), textcolor = color.white, size = size.small)

if showSignals and selectedDetected and not selectedDetected[1]
    label.new(bar_index, high, "SETUP DETECTED\n" + selectedSetup, style = label.style_label_down, color = color.new(color.orange, 10), textcolor = color.white, size = size.tiny)

// ---------- Dashboard ----------
var table dash = table.new(position.top_right, 2, 14, border_width = 1)
if showDashboard and barstate.islast
    table.cell(dash, 0, 0, "IDX CONFIRMATION", text_color = color.white, bgcolor = color.new(color.blue, 35))
    table.cell(dash, 1, 0, executionReady ? "ENTRY READY" : selectedDetected ? "WATCHLIST" : "NO SETUP", text_color = color.white, bgcolor = executionReady ? color.new(color.green, 15) : selectedDetected ? color.new(color.orange, 15) : color.new(color.gray, 45))
    table.cell(dash, 0, 1, "Setup")
    table.cell(dash, 1, 1, selectedSetup)
    table.cell(dash, 0, 2, "Bias")
    table.cell(dash, 1, 2, directionBias + " " + str.tostring(directionScore, "#.0"), text_color = f_bias_color(directionScore))
    table.cell(dash, 0, 3, "IHSG")
    table.cell(dash, 1, 3, marketRegime, text_color = marketRegime == "RISK_OFF" ? color.red : marketRegime == "RISK_ON" ? color.lime : color.orange)
    table.cell(dash, 0, 4, "Entry zone")
    table.cell(dash, 1, 4, na(entryLow) ? "—" : str.tostring(f_round_down(entryLow), format.mintick) + "–" + str.tostring(f_round_up(entryHigh), format.mintick))
    table.cell(dash, 0, 5, "Order entry")
    table.cell(dash, 1, 5, na(entryRounded) ? "—" : str.tostring(entryRounded, format.mintick))
    table.cell(dash, 0, 6, "Stop loss")
    table.cell(dash, 1, 6, na(stopRounded) ? "—" : str.tostring(stopRounded, format.mintick))
    table.cell(dash, 0, 7, "TP1 / TP2")
    table.cell(dash, 1, 7, na(tp1) ? "—" : str.tostring(tp1, format.mintick) + " / " + str.tostring(tp2, format.mintick))
    table.cell(dash, 0, 8, "Risk / RR2")
    table.cell(dash, 1, 8, na(stopPct) ? "—" : str.tostring(stopPct * 100, "#.00") + "% / " + str.tostring(rr2, "#.00"))
    table.cell(dash, 0, 9, "Distance")
    table.cell(dash, 1, 9, str.tostring(selectedDistance, "#.00") + " ATR")
    table.cell(dash, 0, 10, "Vol / CMF")
    table.cell(dash, 1, 10, str.tostring(volRatio, "#.00") + "x / " + str.tostring(cmf20, "#.00"))
    table.cell(dash, 0, 11, "Room to ARA")
    table.cell(dash, 1, 11, na(roomToARA) ? "—" : str.tostring(roomToARA * 100, "#.00") + "%")
    table.cell(dash, 0, 12, "Blocker")
    table.cell(dash, 1, 12, primaryBlocker, text_color = primaryBlocker == "NONE" ? color.lime : color.orange)
    table.cell(dash, 0, 13, "Scanner note")
    table.cell(dash, 1, 13, scannerTag == "" ? "—" : scannerTag)

// ---------- Alerts ----------
alertcondition(executionReady, "IDX Scanner Entry Ready", "IDX Scanner Confirmation: entry setup is ready on the closed bar.")
alertcondition(selectedDetected and not executionReady, "IDX Scanner Watchlist", "IDX Scanner Confirmation: setup detected, but one or more execution gates are not complete.")

if enableDynamicAlert and newReadySignal
    alert("IDX ENTRY READY | " + syminfo.ticker + " | " + selectedSetup + " | Entry " + str.tostring(entryRounded, format.mintick) + " | SL " + str.tostring(stopRounded, format.mintick) + " | TP1 " + str.tostring(tp1, format.mintick) + " | TP2 " + str.tostring(tp2, format.mintick) + " | Bias " + directionBias + " " + str.tostring(directionScore, "#.0"), alert.freq_once_per_bar_close)
